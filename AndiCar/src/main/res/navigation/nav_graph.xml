<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="org.andicar2.activity.MainActivity"
        android:label="@string/app_name"
        tools:layout="@layout/activity_main">
        <action
            android:id="@+id/action_main_to_preferences"
            app:destination="@id/preferencesFragment" />
        <action
            android:id="@+id/action_main_to_about"
            app:destination="@id/aboutFragment" />
    </fragment>

    <fragment
        android:id="@+id/preferencesFragment"
        android:name="andicar.n.activity.preference.PreferenceActivity"
        android:label="@string/preferences" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="andicar.n.activity.miscellaneous.AboutActivity"
        android:label="@string/about" />

</navigation>